# Copy to .env and fill in secrets locally. Do not commit real credentials.

AIDER_MODEL=openai/MiniMax-M2.7-highspeed
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

# Optional extra flags appended to every aider invocation.
# Example: --yes-always --no-auto-commits
AIDER_EXTRA_ARGS=--yes-always --no-auto-commits

# Optional judge hook. If empty, runner/judge.py requires --allow-stub.
# The command receives a judge_input.json path as its final argument.
JUDGE_MODEL=openai/MiniMax-M2.7
JUDGE_COMMAND=

# Optional price model for cost tracking when token counts can be parsed.
# Values are USD per 1M tokens.
AGENT_INPUT_USD_PER_1M=0
AGENT_OUTPUT_USD_PER_1M=0
JUDGE_INPUT_USD_PER_1M=0
JUDGE_OUTPUT_USD_PER_1M=0
