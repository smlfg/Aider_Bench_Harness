{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["scope_adherence", "minimality", "diff_clarity", "judge_score", "rationale"],
  "properties": {
    "scope_adherence": {"type": "number", "minimum": 1, "maximum": 5},
    "minimality": {"type": "number", "minimum": 1, "maximum": 5},
    "diff_clarity": {"type": "number", "minimum": 1, "maximum": 5},
    "judge_score": {"type": "number", "minimum": 1, "maximum": 5},
    "rationale": {"type": "string"}
  }
}

