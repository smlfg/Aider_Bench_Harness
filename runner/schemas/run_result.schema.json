{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["run_id", "task_id", "condition_id", "tests_total", "tests_passed", "task_success"],
  "properties": {
    "run_id": {"type": "string"},
    "task_id": {"type": "string"},
    "condition_id": {"type": "string"},
    "infrastructure_error": {"type": "boolean"},
    "failure_kind": {"type": "string"},
    "tokens_in": {"type": ["integer", "null"]},
    "tokens_out": {"type": ["integer", "null"]},
    "cost_estimate": {"type": ["number", "null"]},
    "tests_total": {"type": "integer"},
    "tests_passed": {"type": "integer"},
    "task_success": {"type": "boolean"}
  }
}
